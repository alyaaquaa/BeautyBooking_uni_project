@page "/employee/create"

@inject IEmployeeClientService EmployeeService
@inject NavigationManager NavigationManager

<h3>Dodaj pracownika</h3>

<EditForm Model="model" OnValidSubmit="Create">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Imię</label>
        <InputText class="form-control" @bind-Value="model.FirstName" />
    </div>

    <div class="mb-3">
        <label>Nazwisko</label>
        <InputText class="form-control" @bind-Value="model.LastName" />
    </div>
    <div class="mb-3">
        <label>Email</label>
        <InputText class="form-control" @bind-Value="model.Email" />
    </div>

    <div class="mb-3">
        <label>Stanowisko</label>
        <InputText class="form-control" @bind-Value="model.Position" />
    </div>

    <button class="btn btn-success" type="submit">Zapisz</button>
    <a href="/employee" class="btn btn-secondary ms-2">Anuluj</a>
</EditForm>

@code {
    private CreateEmployeeDto model = new();

    private async Task Create()
    {
        await EmployeeService.CreateAsync(model);
        NavigationManager.NavigateTo("/employee");
    }
}